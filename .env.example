# Phoenix Cloud
PHOENIX_API_KEY=px_live_xxxxxxxx
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space
PHOENIX_BASE_URL=https://app.phoenix.arize.com/s/your-space
PHOENIX_PROJECT_NAME=agentci

# --- Gemini (target + engineer + judges) ---
# Recommended: Vertex AI (real quota, billed to a GCP project; free-tier AI Studio keys cap at
# ~20 requests/day/model, which can't complete a recording). Auth via Application Default
# Credentials: `gcloud auth application-default login` + `gcloud services enable aiplatform.googleapis.com`.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1     # high-quota region for gemini-2.5-* (global endpoint quota is tiny on fresh projects)
# Alternative: an AI Studio API key instead of Vertex (leave USE_VERTEXAI unset/false).
# GOOGLE_API_KEY=xxxxxxxx

# --- Cross-family ruler (D17/D18): held-out improvement ruler + rubric reviewer ---
# Must be a NON-Gemini family so the agent can't grade its own homework. Pick ONE:
# 1. Claude on Vertex AI (billed to the same GCP project — no extra key, recommended):
ANTHROPIC_USE_VERTEX=true
ANTHROPIC_VERTEX_REGION=global        # Claude Haiku 4.5 on Vertex serves from the global endpoint
# 2. Groq free tier (Llama — still non-Gemini): set GROQ_API_KEY, used when present.
# GROQ_API_KEY=gsk_xxxxxxxx
# 3. Direct Anthropic API:
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- AgentCI behavior ---
AGENTCI_CACHE_MODE=replay   # replay | record | live
AGENTCI_CACHE_DIR=.agentci_cache
# Min seconds between live Gemini calls during record mode (rate gate for fresh-project quota).
AGENTCI_GEMINI_MIN_INTERVAL=1.0
